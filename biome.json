{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!.next",
      "!node_modules",
      "!dist",
      "!build",
      "!out",
      "!coverage",
      "!public",
      "!stubs",
      "!drizzle",
      "!convex/_generated",
      "!**/*.md"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5",
      "bracketSpacing": true,
      "arrowParentheses": "always"
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noEmptyInterface": "off",
        "noArrayIndexKey": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "react": {
                "importNames": ["useEffect"],
                "message": "Use useMountEffect from @/hooks/use-mount-effect, derived state, an event handler, or a key prop instead. See .claude/skills/no-use-effect/SKILL.md."
              }
            }
          }
        }
      },
      "performance": {
        "noImgElement": "off"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "attributes": ["className", "class"],
            "functions": ["clsx", "cva", "cn", "tw", "twMerge"]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.config.js", "**/*.config.mjs", "**/*.config.cjs", "**/*.config.ts"],
      "formatter": { "enabled": false }
    },
    {
      "includes": [
        "hooks/use-mount-effect.ts",
        "hooks/use-event-listener.ts",
        "hooks/use-horizontal-scroll-state.ts",
        "hooks/use-local-storage.ts",
        "hooks/use-scroll.ts",
        "lib/light-dark-providers.tsx",
        "lib/color-provider.tsx",
        "components/old-portfolio/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["components/ui/**", "hooks/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off",
            "useFocusableInteractive": "off",
            "useAriaPropsForRole": "off",
            "useKeyWithClickEvents": "off",
            "noRedundantRoles": "off",
            "useButtonType": "off",
            "noStaticElementInteractions": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          },
          "suspicious": {
            "noDocumentCookie": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    },
    {
      "includes": ["components/ui/shadcn-io/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
