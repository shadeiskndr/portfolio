{
  "name": "shahathir.me",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,convex -c blue,green --kill-others-on-fail \"bun run dev:next\" \"bun run dev:convex\"",
    "dev:next": "next dev",
    "dev:convex": "convex dev",
    "prebuild": "bun run sync:pdfjs",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "sync:pdfjs": "rm -rf public/pdfjs && mkdir -p public/pdfjs/build && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdfjs/build/ && cp -r node_modules/pdfjs-dist/cmaps public/pdfjs/ && cp -r node_modules/pdfjs-dist/standard_fonts public/pdfjs/"
  },
