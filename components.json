{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "base-nova",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@kokonutui": {
      "url": "https://kokonutui.com/r/{name}.json",
      "aliases": {
        "components": "@/components/ui/kokonutui",
        "ui": "@/components/ui/kokonutui"
      }
    },
    "@diceui": {
      "url": "https://diceui.com/r/{name}.json",
      "aliases": {
        "components": "@/components/ui/diceui",
        "ui": "@/components/ui/diceui"
      }
    },
    "@magicui": {
      "url": "https://magicui.design/r/{name}.json",
      "aliases": {
        "components": "@/components/ui/magicui",
        "ui": "@/components/ui/magicui"
      }
    },
    "@smoothui": {
      "url": "https://smoothui.dev/r/{name}.json",
      "aliases": {
        "components": "@/components/ui/smoothui",
        "ui": "@/components/ui/smoothui"
      }
    },
    "@componentry": {
      "url": "https://componentry.fun/r/{name}.json",
      "aliases": {
        "components": "@/components/ui/componentry",
        "ui": "@/components/ui/componentry"
      }
    },
    "@kibo-ui": {
      "url": "https://www.kibo-ui.com/r/{name}.json",
      "aliases": {
        "components": "@/components/ui/kibo-ui",
        "ui": "@/components/ui/kibo-ui"
      }
    }
  }
}
